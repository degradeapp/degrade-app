APP_NAME=Degradê
APP_ENV=local
APP_KEY=
# PRODUÇÃO: APP_DEBUG=false (true vaza stack traces/segredos em telas de erro)
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=America/Manaus
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=degrade
DB_USERNAME=degrade
DB_PASSWORD=degrade_pass_local

SESSION_DRIVER=cookie
SESSION_LIFETIME=129600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUÇÃO (HTTPS): SESSION_SECURE_COOKIE=true — cookie de sessão só trafega em HTTPS
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Fila em banco (tabela jobs); produção roda queue:work via supervisor
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=degrade:

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# Resend Email
RESEND_API_KEY=

# Asaas Billing
ASAAS_API_KEY=
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_SECRET=

# WhatsApp Meta Cloud API
WHATSAPP_API_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Verificação do webhook (produção): token do GET de verify + app secret do HMAC do POST
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Cópia externa do backup (vazio = só local; 'r2' quando existir bucket)
BACKUP_REMOTE_DISK=

# Cloudflare R2
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_ENDPOINT=
