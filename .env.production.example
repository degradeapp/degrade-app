# ============================================================
# DEGRADÊ: .env de PRODUÇÃO (modelo)
# Copie pra /var/www/degrade/.env e preencha linha a linha.
# Depois de qualquer mudança aqui: php artisan config:cache
# ============================================================

APP_NAME=Degradê
APP_ENV=production
# Gere com: php artisan key:generate --force (uma vez, e NUNCA troque depois:
# a chave criptografa sessões e o token do WhatsApp gravado no banco)
APP_KEY=
# false SEMPRE em produção: true vaza stack traces e segredos em telas de erro
APP_DEBUG=false
# Domínio real com https (usado em links de e-mail e no link público de agendamento)
APP_URL=https://SEU_DOMINIO

# Fuso padrão de novas contas; cada loja tem o seu (gravado por tenant)
APP_TIMEZONE=America/Manaus
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# info em produção (debug enche o disco)
LOG_LEVEL=info

# ---------- Banco (PostgreSQL de produção) ----------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=degrade
DB_USERNAME=degrade
# Senha forte gerada na criação do usuário do banco (runbook seção 3)
DB_PASSWORD=

# ---------- Sessão ----------
SESSION_DRIVER=cookie
# 90 dias: dono de barbearia não quer digitar senha toda semana
SESSION_LIFETIME=129600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# true em produção: cookie de sessão só trafega em HTTPS
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ---------- Fila / cache (sem Redis: um VPS só, tabelas já existem) ----------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=degrade:

# ---------- E-mail (Resend) ----------
# Enquanto RESEND_API_KEY estiver vazio, deixe MAIL_MAILER=log (e-mails caem no
# log e NINGUÉM recebe; reset de senha não funciona de verdade).
# Quando o domínio estiver verificado no Resend (SPF/DKIM): MAIL_MAILER=resend
MAIL_MAILER=log
RESEND_API_KEY=
MAIL_FROM_ADDRESS=nao-responda@SEU_DOMINIO
MAIL_FROM_NAME="${APP_NAME}"

# ---------- Asaas (cobrança) ----------
# Chave LIVE (começa com $aact_prod). ASAAS_SANDBOX=false em produção.
ASAAS_API_KEY=
ASAAS_SANDBOX=false
# Secret configurado no painel do Asaas junto com a URL do webhook
# (https://SEU_DOMINIO/api/webhooks/asaas). SEM esse secret o webhook é
# REJEITADO em produção (fail-closed): não deixe vazio com Asaas ativo.
ASAAS_WEBHOOK_SECRET=

# ---------- WhatsApp Meta Cloud API ----------
# Setup manual por cliente na tela /whatsapp/setup (Phone ID + token ficam no
# banco, criptografados). Os dois abaixo são do APP Meta (globais):
# WHATSAPP_VERIFY_TOKEN: string aleatória sua, colada no painel da Meta no GET de verificação
# WHATSAPP_APP_SECRET: App Secret do app Meta, valida o HMAC de cada POST.
# Fail-closed: sem WHATSAPP_APP_SECRET, webhook de produção é rejeitado.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ---------- Sentry (monitoramento de erros) ----------
# Vazio = desligado, zero efeito. Colar o DSN do projeto criado em sentry.io
SENTRY_LARAVEL_DSN=
# Fração de traces de performance (0.0 desliga; 0.1 = 10% das requests)
SENTRY_TRACES_SAMPLE_RATE=0

# ---------- Backup externo (congelado até criar conta R2/S3) ----------
# Vazio = backup fica só no disco local (storage/app/backups, retém 7).
# Quando existir bucket: preencher R2_* abaixo e BACKUP_REMOTE_DISK=r2
BACKUP_REMOTE_DISK=

# Cloudflare R2 (só usado se BACKUP_REMOTE_DISK=r2)
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_ENDPOINT=

VITE_APP_NAME="${APP_NAME}"
